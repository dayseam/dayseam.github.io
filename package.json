{
  "name": "@dayseam/website",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Public marketing site for Dayseam, deployed to https://dayseam.github.io (and eventually dayseam.com). DAY-166, DAY-169. Closes-progress #141.",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "astro check",
    "typecheck": "astro check",
    "build:og": "node scripts/build-og-image.mjs",
    "test": "echo 'Run pnpm test:caption-alignment against a live preview started with pnpm dev or pnpm preview; see tests/caption-alignment.spec.mjs for the run protocol'",
    "test:caption-alignment": "node tests/caption-alignment.spec.mjs"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/react": "^3.6.3",
    "@astrojs/sitemap": "^3.2.1",
    "@astrojs/tailwind": "^5.1.5",
    "astro": "^4.16.18",
    "framer-motion": "^11.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "playwright": "^1.59.1",
    "sharp": "^0.34.5"
  },
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
