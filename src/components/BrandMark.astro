---
// DAY-166. The Convergence brand mark, inlined as SVG.
//
// We inline rather than reference `/dayseam-mark.svg` as an <img>
// so the mark inherits our Tailwind sizing utilities and so its
// colours remain introspectable when a future site-wide palette
// sweep touches the tokens in tailwind.config.mjs. The geometry
// matches the canonical asset at `assets/brand/dayseam-mark.svg` —
// five strands converging into a seam.
//
// `withTile` (default `false`): renders the charcoal
// rounded-square tile that the packaged favicon
// (`public/dayseam-mark.svg`) carries. The on-page default is
// `false` because every site call site (nav, HowItWorks eyebrow)
// sits on a charcoal surface, and a charcoal-on-charcoal tile
// reads as a redundant square outline. The prop exists so a
// future caller that needs the tile — a social share card, an
// og:image generator, a downloadable press kit, anywhere the
// mark will land on arbitrary background chrome — can opt in
// without duplicating the geometry.
//
// The public favicon at `public/dayseam-mark.svg` is the
// canonical tiled version for non-HTML contexts (tabs, bookmark
// bars, PWA launchers). This component stays as the inline
// HTML-context source of truth; keeping both lets Tailwind
// sizing / CSS theming flow through the inline version while
// the favicon asset remains a self-contained raster source.
interface Props {
  size?: number;
  class?: string;
  withTile?: boolean;
}
const {
  size = 40,
  class: className = "",
  withTile = false,
} = Astro.props;
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 1024 1024"
  width={size}
  height={size}
  role="img"
  aria-label="Dayseam"
  class={className}
>
  <title>Dayseam</title>
  {
    withTile && (
      <rect
        x="0"
        y="0"
        width="1024"
        height="1024"
        rx="229"
        ry="229"
        fill="#17171A"
      />
    )
  }
  <g stroke-width="28" stroke-linecap="round" fill="none">
    <line x1="292" y1="230" x2="680" y2="512" stroke="#E89A2C" />
    <line x1="224" y1="364" x2="680" y2="512" stroke="#2B8AA0" />
    <line x1="200" y1="512" x2="680" y2="512" stroke="#D94F6E" />
    <line x1="224" y1="660" x2="680" y2="512" stroke="#5BA567" />
    <line x1="292" y1="794" x2="680" y2="512" stroke="#4D6DD0" />
    <line x1="680" y1="512" x2="980" y2="512" stroke="#F6F1E6" stroke-dasharray="44 24" />
  </g>
</svg>
