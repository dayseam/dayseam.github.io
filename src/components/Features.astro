---
const features = [
  {
    title: "Local-first by design",
    body:
      "The app runs entirely on your Mac. Tokens live in Keychain. There are no Dayseam servers receiving your activity data.",
  },
  {
    title: "Evidence-linked reports",
    body:
      "Every sentence in the generated report is anchored to a commit, issue, merge request, or doc change. Nothing is made up.",
  },
  {
    title: "Works with the tools you already use",
    body:
      "Local Git, GitHub, GitLab, Jira, and Confluence today. More connectors ship regularly. Markdown and file sinks out of the box.",
  },
];
---

<section class="border-t border-slate-200/60 bg-slate-50/50 py-20 dark:border-slate-800 dark:bg-slate-900/40">
  <div class="container-prose">
    <div class="max-w-2xl">
      <h2
        class="text-3xl font-semibold tracking-tight text-slate-900 sm:text-4xl dark:text-white"
      >
        Built for developers who have to explain their day.
      </h2>
      <p class="mt-4 text-lg text-slate-600 dark:text-slate-300">
        Standups, weekly reviews, performance reports. Dayseam assembles the
        evidence so you can focus on the work itself.
      </p>
    </div>

    <dl class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        features.map((feature) => (
          <div
            class="group relative rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:shadow-md dark:border-slate-800 dark:bg-slate-950"
          >
            <dt class="text-base font-semibold text-slate-900 dark:text-white">
              {feature.title}
            </dt>
            <dd class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-300">
              {feature.body}
            </dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>
