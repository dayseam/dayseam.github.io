---
const repoUrl = "https://github.com/vedanthvdev/dayseam";
const releasesUrl = `${repoUrl}/releases/latest`;
---

<section class="relative overflow-hidden">
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(ellipse_at_top,_theme(colors.seam.200/50%),_transparent_60%)] dark:bg-[radial-gradient(ellipse_at_top,_theme(colors.seam.600/20%),_transparent_60%)]"
  >
  </div>
  <div class="container-prose pt-24 pb-20 sm:pt-32 sm:pb-28">
    <div class="mb-8 flex items-center gap-3">
      <span
        class="inline-flex items-center gap-2 rounded-full border border-seam-400/40 bg-seam-100/60 px-3 py-1 text-xs font-medium text-seam-700 dark:border-seam-400/30 dark:bg-seam-400/10 dark:text-seam-200"
      >
        <span class="h-1.5 w-1.5 rounded-full bg-seam-500"></span>
        Public beta
      </span>
      <span class="text-xs text-slate-500 dark:text-slate-400">
        macOS 12+ &middot; Apple Silicon & Intel
      </span>
    </div>

    <h1
      class="text-balance text-4xl font-semibold tracking-tight text-slate-900 sm:text-6xl dark:text-white"
    >
      Your workday,
      <span class="relative inline-block">
        <span class="text-seam-600 dark:text-seam-400">stitched</span>
        <span
          aria-hidden="true"
          class="absolute inset-x-0 -bottom-1 h-[2px] bg-seam-400/70"
        ></span>
      </span>
      from the tools you already use.
    </h1>

    <p
      class="mt-6 max-w-2xl text-pretty text-lg leading-relaxed text-slate-600 sm:text-xl dark:text-slate-300"
    >
      Dayseam is a local-first macOS app that turns your commits, tickets, and docs
      into an evidence-linked daily report. Nothing leaves your Mac.
    </p>

    <div class="mt-10 flex flex-wrap items-center gap-4">
      <a
        href={releasesUrl}
        class="inline-flex items-center justify-center gap-2 rounded-lg bg-slate-900 px-5 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-slate-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-seam-500 dark:bg-white dark:text-slate-900 dark:hover:bg-slate-200"
      >
        Download for macOS
        <svg
          aria-hidden="true"
          viewBox="0 0 20 20"
          fill="currentColor"
          class="h-4 w-4"
        >
          <path
            fill-rule="evenodd"
            d="M10 3a.75.75 0 0 1 .75.75v8.69l2.72-2.72a.75.75 0 1 1 1.06 1.06l-4 4a.75.75 0 0 1-1.06 0l-4-4a.75.75 0 1 1 1.06-1.06l2.72 2.72V3.75A.75.75 0 0 1 10 3ZM3.75 15.5a.75.75 0 0 1 .75.75V17a.5.5 0 0 0 .5.5h10a.5.5 0 0 0 .5-.5v-.75a.75.75 0 0 1 1.5 0V17a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-.75a.75.75 0 0 1 .75-.75Z"
            clip-rule="evenodd"
          ></path>
        </svg>
      </a>
      <a
        href={repoUrl}
        class="inline-flex items-center justify-center gap-2 rounded-lg border border-slate-300 bg-white/80 px-5 py-3 text-sm font-semibold text-slate-800 transition hover:bg-slate-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-seam-500 dark:border-slate-700 dark:bg-slate-900/50 dark:text-slate-100 dark:hover:bg-slate-800"
      >
        <svg
          aria-hidden="true"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="h-4 w-4"
        >
          <path
            d="M12 .5C5.73.5.67 5.58.67 11.86c0 5.02 3.24 9.28 7.74 10.78.56.1.77-.24.77-.55 0-.27-.01-1.15-.02-2.09-3.15.68-3.81-1.34-3.81-1.34-.51-1.3-1.25-1.65-1.25-1.65-1.03-.7.08-.69.08-.69 1.14.08 1.74 1.17 1.74 1.17 1.01 1.73 2.65 1.23 3.29.94.1-.73.4-1.23.72-1.51-2.52-.29-5.17-1.26-5.17-5.6 0-1.24.44-2.25 1.16-3.04-.12-.29-.5-1.44.11-3 0 0 .95-.3 3.11 1.17a10.77 10.77 0 0 1 2.83-.38c.96 0 1.93.13 2.83.38 2.16-1.47 3.11-1.17 3.11-1.17.62 1.56.23 2.71.11 3 .72.79 1.16 1.8 1.16 3.04 0 4.35-2.65 5.3-5.18 5.59.41.35.77 1.04.77 2.1 0 1.52-.01 2.74-.01 3.11 0 .31.2.66.78.55 4.5-1.5 7.73-5.76 7.73-10.77C23.33 5.58 18.27.5 12 .5Z"
          ></path>
        </svg>
        View on GitHub
      </a>
    </div>

    <p class="mt-8 max-w-2xl text-sm text-slate-500 dark:text-slate-400">
      Signed builds ship from GitHub Releases. During public beta some release
      artifacts may require first-run install steps; the download page lists the
      current requirements for each version.
    </p>
  </div>
</section>
