---
// DAY-166. Minimal footer. A product-focused open-source project
// does not need a shop / careers / investor-relations stack here.
//
// `new Date().getFullYear()` resolves at build time (static Astro
// output), which is correct for this site because every release
// triggers a rebuild. Hardcoding the year would drift; resolving
// at runtime would require JS or an edge function. Build-time is
// the right trade-off for a rebuild-on-release site.
const year = new Date().getFullYear();
---

<footer class="border-t border-white/5 bg-charcoal-900 py-10 text-sm text-zinc-500">
  <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 px-6 sm:flex-row">
    <p>
      © {year} Dayseam. MIT licensed
    </p>
    <ul class="flex items-center gap-6">
      <li>
        <a
          href="https://github.com/dayseam/dayseam"
          class="hover:text-zinc-200 focus-visible:text-zinc-200"
          target="_blank"
          rel="noopener noreferrer"
          >Source</a
        >
      </li>
      <li>
        <a
          href="https://github.com/dayseam/dayseam/blob/master/docs/privacy-security.md"
          class="hover:text-zinc-200 focus-visible:text-zinc-200"
          target="_blank"
          rel="noopener noreferrer"
          >Privacy &amp; security</a
        >
      </li>
      <li>
        <a
          href="https://github.com/dayseam/dayseam/releases"
          class="hover:text-zinc-200 focus-visible:text-zinc-200"
          target="_blank"
          rel="noopener noreferrer"
          >Releases</a
        >
      </li>
    </ul>
  </div>
</footer>
