---
// DAY-166. Three-step "how it works" section. Sits between the
// scroll-driven hero (which is emotional and high-level) and the
// connector grid (which is concrete and tool-named) so a reader
// who needs more context than the hero provides gets it without
// having to bounce to docs.
import BrandMark from "./BrandMark.astro";
---

<section
  id="how-it-works"
  class="mx-auto max-w-6xl px-6 py-20"
  aria-label="How Dayseam works in three steps"
>
  <div class="mx-auto max-w-3xl text-center">
    <div class="mb-6 flex items-center justify-center">
      <BrandMark size={52} />
    </div>
    <h2 class="text-balance text-3xl font-semibold text-zinc-50 sm:text-4xl">
      Three steps. No meetings about meetings
    </h2>
    <p class="mt-4 text-balance text-zinc-400">
      Dayseam runs locally on your laptop and produces a daily Markdown report
      that you actually want to read, because every bullet traces back to the
      evidence that produced it
    </p>
  </div>

  <ol class="mt-14 grid gap-6 md:grid-cols-3">
    <li class="relative rounded-2xl border border-white/5 bg-charcoal-700/40 p-6">
      <span class="absolute -top-3 left-6 rounded-full border border-white/10 bg-charcoal-900 px-3 py-1 font-mono text-[11px] uppercase tracking-[0.18em] text-cream">
        01 · connect
      </span>
      <h3 class="mt-3 text-lg font-semibold text-zinc-100">Add the tools you use</h3>
      <p class="mt-2 text-sm leading-relaxed text-zinc-400">
        Paste a GitHub or GitLab token, point at a local repo, or hand over a
        Jira / Confluence URL. Credentials go straight into the macOS Keychain,
        never touch disk
      </p>
    </li>

    <li class="relative rounded-2xl border border-white/5 bg-charcoal-700/40 p-6">
      <span class="absolute -top-3 left-6 rounded-full border border-white/10 bg-charcoal-900 px-3 py-1 font-mono text-[11px] uppercase tracking-[0.18em] text-cream">
        02 · gather
      </span>
      <h3 class="mt-3 text-lg font-semibold text-zinc-100">Dayseam stitches the day</h3>
      <p class="mt-2 text-sm leading-relaxed text-zinc-400">
        Each connector runs on a quiet timer, fetches only what changed, and
        drops it into a local SQLite index. Nothing is sent anywhere
      </p>
    </li>

    <li class="relative rounded-2xl border border-white/5 bg-charcoal-700/40 p-6">
      <span class="absolute -top-3 left-6 rounded-full border border-white/10 bg-charcoal-900 px-3 py-1 font-mono text-[11px] uppercase tracking-[0.18em] text-cream">
        03 · report
      </span>
      <h3 class="mt-3 text-lg font-semibold text-zinc-100">Publish to Markdown or Obsidian</h3>
      <p class="mt-2 text-sm leading-relaxed text-zinc-400">
        Review, edit, and save. Every bullet links back to the commit, ticket,
        or doc it was sourced from, so standup writes itself and review leaves
        a paper trail
      </p>
    </li>
  </ol>
</section>
