---
// DAY-166 / DAY-210. The connector grid — shipping + coming-soon.
//
// Shows the two populations in `~/data/connectors.ts`:
//   - SHIPPING (6 since DAY-210 added Outlook): lit tile,
//     connector-coloured chip, real pitch.
//   - COMING_SOON (5): greyed tile with a "soon" ribbon. Deliberate
//     so a visitor can see the trajectory without us making vapour-
//     ware claims. If one of these ships, flip it to SHIPPING in
//     `connectors.ts`; no other site code needs to change.
//
// Layout note (DAY-210):
//   The shipping shelf is `lg:grid-cols-6` and the coming-soon
//   shelf is `lg:grid-cols-5`. Both render as a single row at lg
//   breakpoint, which is the visual rhythm the section was
//   designed around (two stacked shelves, label above, chips
//   below). Forcing both to the same column count would either
//   leave a trailing empty cell on coming-soon (`grid-cols-6` for
//   both) or wrap the sixth shipping tile to a stub second row
//   (`grid-cols-5` for both — the worst look). Asymmetric column
//   counts keep both shelves single-row at a tiny cost in card
//   width on shipping; the cards remain readable at ~175px wide
//   because the pitches are short enough to wrap to two or three
//   lines either way.
//
// "Open a connector request" link (DAY-210):
//   The link uses `?labels=enhancement&title=Connector+request:+`
//   instead of an issue-template URL because dayseam/dayseam does
//   not currently ship `.github/ISSUE_TEMPLATE/connector_request.md`
//   nor a `connector` label. The previous URL referenced both,
//   which silently no-op'd both query params on GitHub's side and
//   dropped the visitor onto a generic blank issue with no signal
//   that they'd asked for a connector. `enhancement` is one of the
//   default labels that does exist on the repo; the title prefix
//   carries the "connector request" intent without requiring an
//   issue template that may or may not survive future repo cleanup.
import { SHIPPING, COMING_SOON } from "~/data/connectors";
---

<section
  id="connectors"
  class="mx-auto max-w-6xl px-6 py-20"
  aria-label="Connectors Dayseam supports"
>
  <div class="mx-auto max-w-3xl text-center">
    <h2 class="text-balance text-3xl font-semibold text-zinc-50 sm:text-4xl">
      Every surface where work happens
    </h2>
    <p class="mt-4 text-balance text-zinc-400">
      Six connectors ship today. More are on deck, and the connector
      architecture means they arrive as new crates, not rearchitectures
    </p>
  </div>

  <h3 class="mt-14 font-mono text-[11px] uppercase tracking-[0.2em] text-cream/60">
    Shipping today
  </h3>
  <ul class="mt-5 grid gap-5 sm:grid-cols-2 lg:grid-cols-6">
    {
      SHIPPING.map((connector) => (
        <li
          class="group rounded-2xl border border-white/5 bg-charcoal-700/40 p-6 transition-colors hover:border-white/10 hover:bg-charcoal-700/60"
          data-connector-id={connector.id}
        >
          <div
            class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-lg"
            style={`background-color: ${connector.accent}22; color: ${connector.accent};`}
            aria-hidden="true"
          >
            <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor">
              <path d={connector.path} />
            </svg>
          </div>
          <p class="text-sm font-semibold text-zinc-100">{connector.name}</p>
          <p class="mt-2 text-[13px] leading-relaxed text-zinc-400">{connector.pitch}</p>
        </li>
      ))
    }
  </ul>

  <h3 class="mt-14 font-mono text-[11px] uppercase tracking-[0.2em] text-cream/50">
    On deck
  </h3>
  <ul class="mt-5 grid gap-5 sm:grid-cols-2 lg:grid-cols-5">
    {
      COMING_SOON.map((connector) => (
        <li
          class="relative overflow-hidden rounded-2xl border border-white/5 bg-charcoal-700/20 p-6 opacity-70"
          data-connector-id={connector.id}
        >
          <span class="absolute right-3 top-3 rounded-full border border-white/10 bg-charcoal-900/60 px-2 py-0.5 font-mono text-[10px] uppercase tracking-wider text-zinc-400">
            soon
          </span>
          <div
            class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-lg"
            style={`background-color: ${connector.accent}22; color: ${connector.accent};`}
            aria-hidden="true"
          >
            <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor">
              <path d={connector.path} />
            </svg>
          </div>
          <p class="text-sm font-semibold text-zinc-200">{connector.name}</p>
          <p class="mt-2 text-[13px] leading-relaxed text-zinc-500">{connector.pitch}</p>
        </li>
      ))
    }
  </ul>

  <p class="mx-auto mt-12 max-w-2xl text-center text-sm text-zinc-500">
    Want a source that isn't here yet?
    <a
      href="https://github.com/dayseam/dayseam/issues/new?labels=enhancement&title=Connector%20request%3A%20"
      class="text-cream hover:underline focus-visible:underline"
      target="_blank"
      rel="noopener noreferrer"
    >
      Open a connector request →
    </a>
  </p>
</section>
