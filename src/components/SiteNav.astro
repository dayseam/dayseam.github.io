---
// DAY-166. Top-of-page navigation.
//
// Three anchors, one CTA. We resist the temptation to ship a full
// in-site nav (Product / Pricing / Blog / Docs) on day one because
// there are no separate pages yet and a nav with three in-page
// anchors reads as confident and focused rather than empty.
import BrandMark from "./BrandMark.astro";
---

<header class="sticky top-0 z-40 border-b border-white/5 bg-charcoal-900/80 backdrop-blur supports-[backdrop-filter]:bg-charcoal-900/60">
  <nav class="mx-auto flex max-w-6xl items-center justify-between gap-6 px-6 py-3" aria-label="Primary">
    <a href="/" class="flex items-center gap-3" aria-label="Dayseam home">
      <BrandMark size={32} />
      <span class="font-semibold tracking-tight text-zinc-100">Dayseam</span>
    </a>

    <ul class="hidden items-center gap-7 text-sm text-zinc-400 md:flex">
      <li>
        <a href="#how-it-works" class="transition-colors hover:text-zinc-100 focus-visible:text-zinc-100">How it works</a>
      </li>
      <li>
        <a href="#connectors" class="transition-colors hover:text-zinc-100 focus-visible:text-zinc-100">Connectors</a>
      </li>
      <li>
        <a href="#trust" class="transition-colors hover:text-zinc-100 focus-visible:text-zinc-100">Privacy</a>
      </li>
      <li>
        <a
          href="https://github.com/dayseam/dayseam"
          class="transition-colors hover:text-zinc-100 focus-visible:text-zinc-100"
          target="_blank"
          rel="noopener noreferrer"
        >
          GitHub
        </a>
      </li>
    </ul>

    <a
      href="https://github.com/dayseam/dayseam/releases/latest"
      class="inline-flex items-center gap-2 rounded-md border border-cream/20 bg-cream/10 px-4 py-1.5 text-sm font-medium text-cream transition-colors hover:bg-cream/20 focus-visible:bg-cream/20"
      target="_blank"
      rel="noopener noreferrer"
    >
      Download for macOS
    </a>
  </nav>
</header>
