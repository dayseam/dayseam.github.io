---
// DAY-172. Server-rendered placeholder for the `<Hero client:only>`
// island.
//
// The hero is a React island with `client:only="react"` because
// framer-motion's scroll hooks (`useScroll`, `MotionValue`) ship
// browser-only code that breaks Astro's static build. `client:only`
// renders nothing on the server, which up to DAY-171 meant the
// static HTML looked like this on first paint:
//
//     (empty astro-island)
//     <section id="how-it-works">Three steps. No meetings…</section>
//     …
//
// So browsers painted the "How it works" section at the top of
// the viewport, then — a few hundred ms later, when the React
// bundle finished loading — `HeroAnimated` mounted with a
// `h-[300vh]` scroll zone above HowItWorks and shoved everything
// downward. Scroll position stayed at 0, so from the user's
// perspective the page snapped back to the top and the hero
// appeared where HowItWorks had just been. Classic CLS glitch.
//
// This component solves that by being the `slot="fallback"` for
// the hero island. It mirrors HeroAnimated's outer structure —
// `relative h-[300vh]` outer, `sticky top-0 h-screen` inner —
// so the scroll zone is reserved server-side with the same
// dimensions the hydrated animated hero will use. When React
// hydrates HeroAnimated, it replaces this fallback inside the
// astro-island with zero layout shift (same outer height). When
// React hydrates HeroStatic instead (reduced-motion users), the
// container collapses from 300vh to HeroStatic's auto height,
// which is a shift, but (a) reduced-motion users have explicitly
// opted out of motion anyway, and (b) the shift happens once at
// hydration with scroll at 0, so it reads as "the static variant
// loaded" rather than as a mid-read page jump.
//
// As a bonus, the fallback IS the page content for JS-disabled
// visitors — browsers that render astro-island contents as
// static HTML when scripting is off — which means the separate
// `<noscript>` block previously in index.astro is now redundant
// and was removed in DAY-172 alongside this new component.
//
// Design scope: this fallback is a single Convergence-branded
// pitch card, sticky-centred in the viewport, with the same h1
// + pitch copy as HeroStatic. It deliberately does not attempt
// to reproduce the black-hole backdrop or the icon rain — that
// is the point of the animation, and reproducing it statically
// would be both effort-intensive and misleading about what the
// hydrated experience looks like.
import BrandMark from "./BrandMark.astro";
---

<section
  class="relative h-[300vh]"
  aria-label="How Dayseam works, loading an animated walkthrough"
>
  <div
    class="sticky top-0 flex h-screen items-center justify-center overflow-hidden"
  >
    <div
      aria-hidden="true"
      class="absolute inset-0"
      style="background: radial-gradient(circle at 50% 45%, #1f1f24 0%, #14141a 45%, #0a0a0e 100%);"
    >
    </div>

    <div class="relative z-10 mx-auto max-w-3xl px-6 text-center">
      <div class="mb-8 flex items-center justify-center">
        <BrandMark size={72} />
      </div>
      <h1
        class="text-balance text-4xl font-semibold leading-tight text-zinc-50 sm:text-5xl"
      >
        The report of your day, written from evidence
      </h1>
      <p class="mt-5 text-balance text-lg text-zinc-400">
        Dayseam collects what you actually did across GitHub, GitLab, Jira,
        Confluence, and your local repos, then stitches it into an editable
        Markdown report, locally, with no account and no telemetry
      </p>
      <p
        class="mt-8 text-xs uppercase tracking-[0.22em] text-zinc-500"
        aria-hidden="true"
      >
        Scroll to see how
      </p>
    </div>
  </div>
</section>
